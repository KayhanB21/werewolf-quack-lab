DUCKDB_VERSION=v1.5.2

# Set true and restart to expose post_game_intents/full_log rows.
POST_GAME=false

# Agent action mode. The smoke test uses stub so it never needs network access.
LLM_PROVIDER=stub
LLM_MODEL=stub-werewolf-v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60

# Local oMLX option:
# 1. Start oMLX on the host.
# 2. Use host.docker.internal so player containers can reach the host server.
# LLM_PROVIDER=omlx
# LLM_MODEL=<model-id-from-http://localhost:8000/v1/models>
# LLM_BASE_URL=http://host.docker.internal:8000/v1
# LLM_API_KEY=<only-if-oMLX-api-key-auth-is-enabled>
