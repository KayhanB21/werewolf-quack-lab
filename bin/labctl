#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG_PATH="${CONFIG_PATH:-config/game.sample.json}"
OUT_DIR="${OUT_DIR:-.generated}"
ROUND="${ROUND:-1}"
COMPOSE_FILES=(-f docker-compose.yml -f "${OUT_DIR}/docker-compose.yml")

cd "${ROOT_DIR}"

usage() {
  cat <<'USAGE'
Usage: ./bin/labctl <command>

Commands:
  generate        Generate .generated/docker-compose.yml from CONFIG_PATH
  up              Generate and start the lab
  down            Stop the generated lab and remove volumes
  run-agent <id> <phase>
                  Ask one player container to take one action
                  phase is one of: day, vote, wolf, seer, doctor
  run-day         Ask every player container to take one day action
  run-wolf        Ask every wolf container to take one wolf action
  query <name>    Run a gateway query
  ref-knowledge <id> <round> <source> <content>
                  Referee writes a knowledge row into one player's private DB
  ref-reveal <id> <round> <text>
                  Referee writes a public role-reveal row into one player's DB
  smoke           Generate, start, run agent actions, and verify Quack behavior
  config          Render the merged Docker Compose config

Environment:
  CONFIG_PATH     Config JSON path, default config/game.sample.json
  ROUND           Round number for run-day/run-wolf, default 1
USAGE
}

ensure_generated() {
  if [[ ! -f "${OUT_DIR}/docker-compose.yml" || ! -f "${OUT_DIR}/players.json" ]]; then
    ./bin/generate-compose.sh --config "${CONFIG_PATH}" --out-dir "${OUT_DIR}"
  fi
}

compose() {
  docker compose "${COMPOSE_FILES[@]}" "$@"
}

players_matching() {
  local filter="$1"
  jq -r "${filter}" "${OUT_DIR}/players.json"
}

all_player_ids() {
  jq -r '[.[].id] | join(",")' "${OUT_DIR}/players.json"
}

player_exists() {
  local id="$1"
  jq -e --arg id "${id}" 'any(.[]; .id == $id)' "${OUT_DIR}/players.json" >/dev/null
}

run_agent_action() {
  local phase="$1"
  local filter="$2"
  ensure_generated
  while IFS= read -r id; do
    [[ -z "${id}" ]] && continue
    echo "[labctl] ${id} acts in ${phase}"
    compose exec -T "${id}" /app/bin/agent-act.sh --phase "${phase}" --round "${ROUND}" < /dev/null
  done < <(players_matching "${filter}")
}

run_one_agent_action() {
  local id="$1"
  local phase="$2"
  local active_player_ids="${ACTIVE_PLAYER_IDS:-}"
  ensure_generated

  if ! player_exists "${id}"; then
    echo "unknown player: ${id}" >&2
    exit 2
  fi

  case "${phase}" in
    day|vote|wolf|seer|doctor) ;;
    *)
      echo "unknown phase: ${phase}" >&2
      exit 2
      ;;
  esac

  if [[ -z "${active_player_ids}" ]]; then
    active_player_ids="$(all_player_ids)"
  fi

  echo "[labctl] ${id} acts in ${phase}"
  compose exec -T -e "PLAYER_IDS=${active_player_ids}" "${id}" \
    /app/bin/agent-act.sh --phase "${phase}" --round "${ROUND}" < /dev/null
}

sql_quote() {
  local value="${1//\'/\'\'}"
  printf "'%s'" "${value}"
}

ref_write_sql() {
  local id="$1"
  local sql="$2"
  ensure_generated
  if ! player_exists "${id}"; then
    echo "unknown player: ${id}" >&2
    exit 2
  fi
  compose exec -T "${id}" bash -lc "cat > /tmp/${id}-duckdb.fifo" <<<"${sql}"
}

ref_knowledge() {
  local id="${1:?ref-knowledge requires a player id}"
  local round="${2:?ref-knowledge requires a round}"
  local source="${3:?ref-knowledge requires a source}"
  local content="${4:?ref-knowledge requires content}"
  local source_sql content_sql id_sql
  source_sql="$(sql_quote "${source}")"
  content_sql="$(sql_quote "${content}")"
  id_sql="$(sql_quote "${id}")"
  ref_write_sql "${id}" "INSERT INTO knowledge (round, agent_id, source, content, confidence, created_at) VALUES (${round}, ${id_sql}, ${source_sql}, ${content_sql}, 1.0, now());"
  echo "[labctl] wrote knowledge row for ${id}"
}

ref_reveal() {
  local id="${1:?ref-reveal requires a player id}"
  local round="${2:?ref-reveal requires a round}"
  local text="${3:?ref-reveal requires public text}"
  local id_sql text_sql
  id_sql="$(sql_quote "${id}")"
  text_sql="$(sql_quote "${text}")"
  ref_write_sql "${id}" "INSERT INTO intents (round, agent_id, action, target, rationale, public_text, decided_at) VALUES (${round}, ${id_sql}, 'role-reveal', NULL, NULL, ${text_sql}, now());"
  echo "[labctl] wrote role-reveal row for ${id}"
}

case "${1:-}" in
  generate)
    ./bin/generate-compose.sh --config "${CONFIG_PATH}" --out-dir "${OUT_DIR}"
    ;;
  up)
    ./bin/generate-compose.sh --config "${CONFIG_PATH}" --out-dir "${OUT_DIR}"
    compose up --build -d --force-recreate
    ;;
  down)
    ensure_generated
    compose down -v
    ;;
  run-agent)
    run_one_agent_action "${2:?run-agent requires a player id}" "${3:?run-agent requires a phase}"
    ;;
  run-day)
    run_agent_action "day" '.[].id'
    ;;
  run-wolf)
    run_agent_action "wolf" '.[] | select(.role == "wolf") | .id'
    ;;
  query)
    ensure_generated
    query_name="${2:-public_log}"
    compose exec gateway /app/bin/gateway-query.sh "${query_name}"
    ;;
  ref-knowledge)
    ref_knowledge "${2:-}" "${3:-}" "${4:-}" "${5:-}"
    ;;
  ref-reveal)
    ref_reveal "${2:-}" "${3:-}" "${4:-}"
    ;;
  smoke)
    ./bin/generate-compose.sh --config "${CONFIG_PATH}" --out-dir "${OUT_DIR}"
    compose up --build -d --force-recreate
    run_agent_action "day" '.[].id'
    run_agent_action "wolf" '.[] | select(.role == "wolf") | .id'
    compose exec -T gateway /app/bin/gateway-smoke-test.sh
    ;;
  config)
    ensure_generated
    compose config
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
